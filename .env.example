# ════════════════════════════════════════════════════════
# Claude Hive — Environment Variables
# ════════════════════════════════════════════════════════
# Copy to .env and fill in your values. NEVER commit .env.

# ── Claude Auth ──
# NOTE: Do NOT set ANTHROPIC_API_KEY here.
# Max plan auth uses interactive login, not API keys.
# API keys override your subscription and charge API rates.
# Login once via: docker compose run --rm <container> claude

# ── GitHub ──
# GITHUB_TOKEN is required: needs `repo`, `read:org`, and `workflow` scopes
# so `gh` CLI can list/create/merge PRs and read CI status.
GITHUB_TOKEN=
# GIT_USER_NAME / GIT_USER_EMAIL are unused by the hub itself. Configure
# them inside individual containers via `git config --global` if needed.

# ── ML Experiment Tracking (GPU containers only) ──
WANDB_API_KEY=
HF_TOKEN=

# ── CompBio (optional) ──
NCBI_API_KEY=

# ── Hub settings (defaults shown) ──
HIVE_HOST=127.0.0.1
HIVE_PORT=8420

# Colon-separated list of host directories the hub scans for
# unregistered `.devcontainer/devcontainer.json` folders (Provisioner
# Discover tab). Depth is capped at 3 levels under each root. Defaults
# to ~/repos:~/projects:~/code:~/src:~/dev:~/workspace — nonexistent
# entries are silently skipped.
# HIVE_DISCOVER_ROOTS=~/repos:~/projects

# ── GitHub Actions (NOT used in containers) ──
# Store ANTHROPIC_API_KEY as a GitHub repo secret, not here.
# This is the ONLY place API key auth is needed — for @claude
# PR automation that runs in GitHub's cloud, not your Docker host.
