# ════════════════════════════════════════════════════════
# Claude Hive — Environment Variables
# ════════════════════════════════════════════════════════
# Copy to .env and fill in your values. NEVER commit .env.

# ── Claude Auth ──
# NOTE: Do NOT set ANTHROPIC_API_KEY here.
# Max plan auth uses interactive login, not API keys.
# API keys override your subscription and charge API rates.
# Login once via: docker compose run --rm <container> claude

# ── GitHub ──
# GITHUB_TOKEN is required: needs `repo`, `read:org`, and `workflow` scopes
# so `gh` CLI can list/create/merge PRs and read CI status.
GITHUB_TOKEN=
# GIT_USER_NAME / GIT_USER_EMAIL are unused by the hub itself. Configure
# them inside individual containers via `git config --global` if needed.

# ── ML Experiment Tracking (GPU containers only) ──
WANDB_API_KEY=
HF_TOKEN=

# ── CompBio (optional) ──
NCBI_API_KEY=

# ════════════════════════════════════════════════════════
# Hub settings — these mirror HiveSettings in hub/config.py.
# All HIVE_* keys are optional; defaults shown are what
# HiveSettings uses when the variable is absent.
# ════════════════════════════════════════════════════════

# Interface the hub binds to. Default keeps the hub reachable only from
# localhost. Setting 0.0.0.0 will be safe once HIVE_AUTH_TOKEN is also
# set (M3 enforces the bearer token on every endpoint).
HIVE_HOST=127.0.0.1

# TCP port for the hub. The Vite dev server proxies /api and /ws here.
HIVE_PORT=8420

# SQLite registry location. Parent directory is created on first run.
# HIVE_DB_PATH=~/.claude-hive/registry.db

# Colon-separated list of host directories the hub scans for
# unregistered `.devcontainer/devcontainer.json` folders (Provisioner
# Discover tab). Depth is capped at 3 levels under each root. Defaults
# to ~/repos:~/projects:~/code:~/src:~/dev:~/workspace — nonexistent
# entries are silently skipped. A JSON list is also accepted.
# HIVE_DISCOVER_ROOTS=~/repos:~/projects

# Bearer token gating every HTTP + WebSocket endpoint. Priority:
#   1. HIVE_AUTH_TOKEN env (this variable) — used in CI and multi-hub
#   2. ~/.config/honeycomb/token  — preferred for local dev
#   3. Auto-generated on first start; printed to stdout and saved to
#      the file above. The dashboard prompts for this value.
# The hub always requires a token; there is no "unauthed" mode. Rotate
# by deleting the token file (or changing this env var) and restarting.
# HIVE_AUTH_TOKEN=

# Origins the CORS middleware allows. Comma-separated or JSON list.
# Default covers the Vite dev server. Wildcard "*" is still valid but
# logs a loud warning — combined with a 0.0.0.0 bind and a shared token
# it is equivalent to a public hub.
# HIVE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Root log level for the hub. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
# HIVE_LOG_LEVEL=INFO

# Log renderer. `json` (production), `pretty` (dev console), or `auto`
# (JSON when stderr is not a TTY, pretty otherwise).
# HIVE_LOG_FORMAT=auto

# Prometheus /metrics endpoint toggle. When `false`, /metrics returns 404.
# HIVE_METRICS_ENABLED=true

# ── GitHub Actions (NOT used in containers) ──
# Store ANTHROPIC_API_KEY as a GitHub repo secret, not here.
# This is the ONLY place API key auth is needed — for @claude
# PR automation that runs in GitHub's cloud, not your Docker host.
